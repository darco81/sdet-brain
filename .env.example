# SDET Brain - environment template. Copy to `.env` and fill in real values.
# Variables map to fields on `sdet_brain.config.Settings`; the headline
# blocks are below. Not every field is listed - see config.py for the full set.

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
# Leave empty for local dev; required on production VPS (Tier 3).
QDRANT_API_KEY=
COLLECTION_NAME=sdet_brand_v1

# --- Embeddings ---
# Primary provider: "mlx" (local M-series) or "gemini" (cloud fallback).
EMBEDDING_PROVIDER=mlx
MLX_MODEL=mlx-community/Qwen3-Embedding-8B-4bit-DWQ
MLX_VECTOR_SIZE=1024
# MLX_MRL_TRUNCATE_TO=1024   # Matryoshka truncation length; None = native dim
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_VECTOR_SIZE=1024

# --- Server ---
SERVER_HOST=127.0.0.1
SERVER_PORT=8080
MCP_SSE_PORT=8081
LOG_LEVEL=INFO

# --- Ingestion ---
CHUNK_TARGET_CHARS=800
CHUNK_OVERLAP_RATIO=0.15
EMBED_BATCH_SIZE=32
# Comma-separated absolute paths the watcher monitors (T1-08).
WATCH_PATHS=
WATCHER_DEBOUNCE_MS=300

# --- Reranking (T2-04) ---
# Cross-encoder reranks an over-fetched candidate set so accuracy
# benefits from a slow precise model without paying its cost on the
# whole index. Disabled by default; opt-in per request via the
# `rerank` field on POST /search.
RERANK_ENABLED=false
RERANK_MODEL=jinaai/jina-reranker-v2-base-multilingual
RERANK_TOP_K_RETRIEVE=30
RERANK_TOP_K_RETURN=5

# --- LLM router (local MLX, M-series only) ---
# Powers the /chat route and the 3 LLM-backed MCP tools. Ignored if you
# don't run the chat surface.
LLM_MODEL=mlx-community/Qwen3-Next-80B-A3B-Instruct-4bit
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.7
LLM_ROUTING_ENABLED=true
LLM_FAST_MODEL=mlx-community/gemma-4-26B-A4B-it-OptiQ-4bit
LLM_REASONING_MODEL=mlx-community/Qwen3-Next-80B-A3B-Thinking-4bit
LLM_ROUTER_CACHE_SIZE=1

# --- OCR (image / PDF ingestion) ---
# Provider: "mlx-vlm" (M-series) or "ollama". Tune the limits for your box.
OCR_PROVIDER=mlx-vlm
OCR_MLX_VLM_MODEL=mlx-community/DeepSeek-OCR-2-6bit
OCR_OLLAMA_PRIMARY_MODEL=deepseek-ocr
OCR_OLLAMA_FALLBACK_MODEL=qwen2.5-vl:32b
OCR_TIMEOUT_SECONDS=120
OCR_MAX_IMAGE_DIM=1600
OCR_MAX_IMAGE_BYTES=20000000
OCR_MAX_PDF_PAGES=20
OCR_KEEP_ALIVE=5m
OCR_QUALITY_MIN_CHARS=50
OCR_PII_SCRUB=false
# Prompt overrides (OCR_GROUNDING_PROMPT / OCR_GENERAL_PROMPT) exist too.

# --- Corpus source paths (per source_type) ---
# Each is a comma-separated list of absolute directories. Empty means
# "no roots for this source_type" - files outside all roots fall back
# to source_type=unknown. Point each at the directory tree you want
# classified into that source_type. Example:
#   DRAFTS_PATHS=/path/to/your/markdown/corpus
PROJECT_KNOWLEDGE_PATHS=
DRAFTS_PATHS=
ARTICLES_PATHS=
SPRINT_REPORTS_PATHS=
BRIEF_PATHS=
